---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const news = await getCollection('news', ({ data }) => !data.draft);
  return news.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data.date;
const fmt = `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base title={entry.data.title}>
  <div class="page-head"><h1>お知らせ</h1></div>
  <section class="section">
    <div class="wrap">
      <article class="article">
        <div class="meta">
          <time>{fmt}</time>
          <span class="cat" style="background:var(--brown);color:#fff;font-size:11px;border-radius:10px;padding:2px 10px;">
            {entry.data.category}
          </span>
        </div>
        <h1>{entry.data.title}</h1>
        <div class="content">
          <Content />
        </div>
      </article>
      <a class="back" href="/news/">← お知らせ一覧へ戻る</a>
    </div>
  </section>
</Base>
