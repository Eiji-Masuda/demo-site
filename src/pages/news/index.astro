---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const news = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base title="お知らせ">
  <div class="page-head"><h1>お知らせ</h1></div>
  <section class="section">
    <div class="wrap">
      <div class="news-list">
        {news.map((n) => (
          <a class="news-item" href={`/news/${n.slug}/`}>
            <time>{fmt(n.data.date)}</time>
            <span class="cat">{n.data.category}</span>
            <span class="t">{n.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
