---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base>
  <div class="hero">
    <h1>心あたたまる一杯を、あなたのそばに。</h1>
    <p>自家焙煎スペシャルティコーヒーと手作り焼き菓子の店「カフェひだまり」</p>
  </div>

  <section class="section">
    <div class="wrap">
      <h2>お知らせ</h2>
      <div class="sub">NEWS</div>
      <div class="news-list">
        {news.map((n) => (
          <a class="news-item" href={`/news/${n.slug}/`}>
            <time>{fmt(n.data.date)}</time>
            <span class="cat">{n.data.category}</span>
            <span class="t">{n.data.title}</span>
          </a>
        ))}
      </div>
      <div class="more"><a class="btn" href="/news/">お知らせ一覧へ</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap">
      <h2>こだわりの三品</h2>
      <div class="sub">RECOMMENDED</div>
      <div class="cards">
        <div class="card">
          <img src="/img/menu-blend.svg" alt="ひだまりブレンド" />
          <div class="body">
            <h3>ひだまりブレンド</h3>
            <p>浅煎りと深煎りを合わせた、やわらかな甘みの看板ブレンド。</p>
            <div class="price">580円（税込）</div>
          </div>
        </div>
        <div class="card">
          <img src="/img/menu-latte.svg" alt="はちみつカフェラテ" />
          <div class="body">
            <h3>はちみつカフェラテ</h3>
            <p>国産はちみつのやさしい甘さと、ふわふわのミルクフォーム。</p>
            <div class="price">680円（税込）</div>
          </div>
        </div>
        <div class="card">
          <img src="/img/menu-scone.svg" alt="全粒粉スコーン" />
          <div class="body">
            <h3>全粒粉スコーン</h3>
            <p>毎朝店内で焼き上げる、ざくざく食感の定番焼き菓子。</p>
            <div class="price">380円（税込）</div>
          </div>
        </div>
      </div>
      <div class="more"><a class="btn" href="/menu/">メニューを見る</a></div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>営業時間・アクセス</h2>
      <div class="sub">SHOP INFO</div>
      <table class="info-table">
        <tbody>
          <tr><th>営業時間</th><td>11:00〜19:00（ラストオーダー 18:30）</td></tr>
          <tr><th>定休日</th><td>毎週水曜日・年末年始</td></tr>
          <tr><th>所在地</th><td>〒550-0000 大阪府大阪市西区ひだまり町1-2-3</td></tr>
          <tr><th>アクセス</th><td>地下鉄「ひだまり駅」2番出口から徒歩3分</td></tr>
          <tr><th>電話</th><td>06-0000-0000</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</Base>
